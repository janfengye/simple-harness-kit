node_modules/
.DS_Store
*.log
.env
.env.*
tmp/
.harness/
docs/verification-report.md

# Local preset selection — each machine picks its own preset (not committed).
# See methodology/19-company-presets.md for how to author and vendor presets.
.harness.local.json

# Private / dogfooded presets — internal preset content (e.g. real company rules)
# stays out of this public repo. See methodology/19 §"公开 vs 私有 preset".
# Use the _local- prefix so future legitimate public presets like
# `team-collab` (hypothetical) wouldn't be silently masked by a too-broad glob.
presets/_local-*/

# Dogfooding artifacts — this kit dogfoods its own harness, so .claude/ and
# .codex/ here are *instances* generated by harness-init for the kit's own
# development, not templates to ship. The distributable templates live in
# templates/, methodology/, and skills/. Shipping these instances would
# confuse users who clone the kit expecting templates, not a wired-up project.
.claude/
.codex/

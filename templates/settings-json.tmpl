{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-session-start.js" }
        ],
        "description": "新 session 重置陈旧阶段 + 输出入口 banner"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "强制声明 Harness 阶段，防止新 session 不遵守流程"
      },
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "强制声明 Harness 阶段，防止新 session 不遵守流程"
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "强制声明 Harness 阶段，防止新 session 不遵守流程"
      },
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "强制声明 Harness 阶段，防止新 session 不遵守流程"
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "强制声明 Harness 阶段，防止新 session 不遵守流程"
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "强制声明 Harness 阶段（PLAN 阶段注入 directive）"
      },
      {
        "matcher": "Grep",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "强制声明 Harness 阶段（PLAN 阶段注入 directive）"
      },
      {
        "matcher": "Glob",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "强制声明 Harness 阶段（PLAN 阶段注入 directive）"
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "强制声明 Harness 阶段（PLAN 阶段注入 directive）"
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "强制声明 Harness 阶段（PLAN 阶段注入 directive）"
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/safety-guard.js" }
        ],
        "description": "拦截危险命令（rm -rf, force push, DROP TABLE 等）"
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/verification-gate.js" }
        ],
        "description": "提交前检查 QA 验证是否完成"
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/delivery-review.js" }
        ],
        "description": "交付前触发 5 项复盘检查"
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/commit-check.js" }
        ],
        "description": "AI commit 必须包含 Co-Authored-By + REVIEW 阶段检查未提交变更"
      },
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/agent-check.js" }
        ],
        "description": "修复类 Agent 必须引用 Constraint ID"
      },
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/context-monitor.js" }
        ],
        "description": "上下文预算监控，超阈值提醒 compact"
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/context-monitor.js" }
        ],
        "description": "上下文预算监控，超阈值提醒 compact"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/session-logger.js" }
        ],
        "description": "记录 Agent 派发到 session-log"
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/session-logger.js" }
        ],
        "description": "记录 Bash 命令到 session-log"
      },
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/session-logger.js" }
        ],
        "description": "记录文件编辑到 session-log"
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/session-logger.js" }
        ],
        "description": "记录文件创建到 session-log"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/session-logger.js" }
        ],
        "description": "记录失败工具调用到 session-log + observations"
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/harness-stage-guard.js" }
        ],
        "description": "任务标记完成时提醒检查 VERIFY 证据（含 agent team 场景）"
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/hooks/delivery-gate.js" }
        ],
        "description": "交付前合规检查——阻止在 EXECUTE/VERIFY(无证据) 阶段宣称完成"
      }
    ]
  }
}

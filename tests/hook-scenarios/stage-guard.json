      "exitCode": 0,
      "stderr": ["EXECUTE", "TDD"],
      "stdout": "passthrough"
    }
  },
  {
    "name": "stage-guard: 过期 stage → 放行 + 过期提醒",
    "hook": "harness-stage-guard.js",
    "stdin": { "tool_name": "Read", "tool_input": { "file_path": "foo.md" } },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"EXECUTE\",\"since\":\"2020-01-01T00:00:00Z\",\"task\":\"old task\"}",
      ".harness/tool-count.json": "{\"count\":1}"
    },
    "expect": {
      "exitCode": 0,
      "stderr": ["超过 2 小时"],
      "stdout": "passthrough"
    }
  },
  {
    "name": "stage-guard: 无效 stage 值 → 阻止",
    "hook": "harness-stage-guard.js",
    "stdin": { "tool_name": "Read", "tool_input": { "file_path": "foo.md" } },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"INVALID\",\"since\":\"2026-04-03T00:00:00Z\"}",
      ".harness/tool-count.json": "{\"count\":1}"
    },
    "expect": {
      "exitCode": 2,
      "stderr": ["无效的阶段值"]
    }
  },
  {
    "name": "stage-guard: 切 REVIEW 无历史无证据 → 阻止",
    "hook": "harness-stage-guard.js",
    "stdin": {
      "tool_name": "Write",
      "tool_input": {
        "file_path": ".harness/current-stage.json",
        "content": "{\"stage\":\"REVIEW\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}"
      }
    },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"VERIFY\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}",
      ".harness/tool-count.json": "{\"count\":1}"
    },
    "expect": {
      "exitCode": 2,
      "stderr": ["切换到 REVIEW 被阻止", "C-GATE-01"]
    }
  },
  {
    "name": "stage-guard: 切 REVIEW 有历史有证据 → 放行",
    "hook": "harness-stage-guard.js",
    "stdin": {
      "tool_name": "Write",
      "tool_input": {
        "file_path": ".harness/current-stage.json",
        "content": "{\"stage\":\"REVIEW\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}"
      }
    },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"VERIFY\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}",
      ".harness/tool-count.json": "{\"count\":1}",
      ".harness/stage-history.jsonl": "{\"stage\":\"PLAN\",\"t\":\"2026-04-03T00:00:00Z\"}\n{\"stage\":\"EXECUTE\",\"t\":\"2026-04-03T00:10:00Z\"}\n{\"stage\":\"VERIFY\",\"t\":\"2026-04-03T00:20:00Z\"}\n",
      ".harness/verify-evidence.md": "# Verification\nAll tests passed."
    },
    "expect": {
      "exitCode": 0,
      "stderr": ["阶段切换"]
    }
  },
  {
    "name": "stage-guard: 切 REVIEW 有历史但无证据 → 阻止",
    "hook": "harness-stage-guard.js",
    "stdin": {
      "tool_name": "Write",
      "tool_input": {
        "file_path": ".harness/current-stage.json",
        "content": "{\"stage\":\"REVIEW\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}"
      }
    },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"VERIFY\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}",
      ".harness/tool-count.json": "{\"count\":1}",
      ".harness/stage-history.jsonl": "{\"stage\":\"PLAN\",\"t\":\"2026-04-03T00:00:00Z\"}\n{\"stage\":\"EXECUTE\",\"t\":\"2026-04-03T00:10:00Z\"}\n{\"stage\":\"VERIFY\",\"t\":\"2026-04-03T00:20:00Z\"}\n"
    },
    "expect": {
      "exitCode": 2,
      "stderr": ["切换到 REVIEW 被阻止", "验证证据"]
    }
  },
  {
    "name": "stage-guard: 切 EXECUTE（非 REVIEW）→ 放行无 Gate",

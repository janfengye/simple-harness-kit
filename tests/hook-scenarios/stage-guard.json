    },
    "expect": {
      "exitCode": 0,
      "stderr": ["交付前", "真实验证"],
      "stdout": "passthrough"
    }
  },
  {
    "name": "stage-guard: EXECUTE + TaskUpdate(completed) → 放行 + 提醒",
    "hook": "harness-stage-guard.js",
    "stdin": { "tool_name": "TaskUpdate", "tool_input": { "taskId": "1", "status": "completed" } },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"EXECUTE\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}",

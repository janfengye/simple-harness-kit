  },
  {
    "name": "stage-guard: OFF → 放行 + 提醒",
    "hook": "harness-stage-guard.js",
    "stdin": { "tool_name": "Bash", "tool_input": { "command": "ls" } },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"OFF\",\"since\":\"2026-04-03T00:00:00Z\",\"reason\":\"测试\"}",
      ".harness/tool-count.json": "{\"count\":1}"
    },
    "expect": {
      "exitCode": 0,
      "stderr": ["Harness 模式已关闭"],
      "stdout": "passthrough"
    }
  },
  {
    "name": "stage-guard: EXECUTE → 放行 + 注入阶段要求",
    "hook": "harness-stage-guard.js",
    "stdin": { "tool_name": "Bash", "tool_input": { "command": "npm test" } },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"EXECUTE\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}",

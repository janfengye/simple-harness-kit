[
  {
    "name": "stage-guard: 无 stage 文件 → 阻止",
    "hook": "harness-stage-guard.js",
    "stdin": { "tool_name": "Bash", "tool_input": { "command": "ls" } },
    "expect": {
      "exitCode": 2,
      "stderr": ["未声明当前 Harness 阶段"]
    }
  },
  {
    "name": "stage-guard: 无 stage 文件但写 stage 文件 → 放行",
    "hook": "harness-stage-guard.js",
    "stdin": {
      "tool_name": "Write",
      "tool_input": { "file_path": ".harness/current-stage.json" }
    },
    "expect": {
      "exitCode": 0,
      "stderr": ["正在创建阶段声明"]
    }
  },
  {
    "name": "stage-guard: PLAN 阶段首次调用 → 阻止（强制声明）",
    "hook": "harness-stage-guard.js",
    "stdin": { "tool_name": "Read", "tool_input": { "file_path": "foo.md" } },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"PLAN\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}",
      ".harness/tool-count.json": "{\"count\":0}"
    },
    "expect": {
      "exitCode": 2,
      "stderr": ["这是本轮任务的第一次工具调用"]
    }
  },
  {
    "name": "stage-guard: PLAN + Read → 放行",
    "hook": "harness-stage-guard.js",
    "stdin": { "tool_name": "Read", "tool_input": { "file_path": "foo.md" } },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"PLAN\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}",
      ".harness/tool-count.json": "{\"count\":1}"
    },
    "expect": {
      "exitCode": 0,
      "stderr": ["PLAN 阶段"],
      "stdout": "passthrough"
    }
  },
  {
    "name": "stage-guard: PLAN + Grep → 放行",
    "hook": "harness-stage-guard.js",

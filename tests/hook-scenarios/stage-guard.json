    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"PLAN\",\"since\":\"2026-04-03T00:00:00Z\",\"task\":\"test\"}",
      ".harness/tool-count.json": "{\"count\":1}"
    },
    "expect": {
      "exitCode": 0,
      "stdout": "passthrough"
    }
  },
  {
    "name": "stage-guard: PLAN + Bash → 阻止",

  {
    "name": "verification-gate: C-GATE-07 kit + 触及 install.sh + 证据缺 Codex → 阻止",
    "hook": "verification-gate.js",
    "stdin": { "tool_name": "Bash", "tool_input": { "command": "git commit -m 'touch install.sh'" } },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"VERIFY\",\"since\":\"2020-01-01T00:00:00Z\",\"task\":\"test\"}",
      ".harness/verify-evidence.md": "# Evidence\n独立 agent: ✓\nClaude Code CLI: ✓\n(第三 runtime 缺失)",
      "tests/template-integrity.js": "// kit marker",
      "install.sh": "#!/bin/sh\necho hi"
    },
    "gitSetup": { "stage": ["install.sh"] },
    "expect": {
      "exitCode": 2,
      "stderr": ["C-GATE-07", "install.sh", "Codex"]
    }
  },
  {
    "name": "verification-gate: C-GATE-07 kit + 触及 install.sh + 证据三模式齐全 → 放行",
    "hook": "verification-gate.js",
    "stdin": { "tool_name": "Bash", "tool_input": { "command": "git commit -m 'touch install.sh'" } },
    "setup": {
      ".harness/current-stage.json": "{\"stage\":\"VERIFY\",\"since\":\"2020-01-01T00:00:00Z\",\"task\":\"test\"}",
      ".harness/verify-evidence.md": "# Evidence\n独立 agent: ✓（前次）\nClaude Code CLI: ✓（前次）\nCodex CLI: ✓（本次 --full-auto）",
      "tests/template-integrity.js": "// kit marker",
      "install.sh": "#!/bin/sh\necho hi"
    },
    "gitSetup": { "stage": ["install.sh"] },
    "expect": {
      "exitCode": 0,
      "stdout": "empty"
    }
  },
  {

[
  {
    "name": "session-logger: Bash 工具 → 写入 session-log + observations",
    "hook": "session-logger.js",
    "stdin": {
      "tool_name": "Bash",
      "tool_input": {
        "command": "npm test"
      },
      "session_id": "test-session-001"
    },
    "setup": {
      ".harness/.gitkeep": ""
    },
    "expect": {
      "exitCode": 0,
      "stdout": "empty",
      "files": {
        ".harness/session-log.md": {
          "contains": "Bash 执行"
        },
        ".harness/observations.jsonl": {
          "contains": "npm test"
        }
      }
    }
  },
  {
    "name": "session-logger: Bash 成功 → observations 含 status=success",
    "hook": "session-logger.js",
    "stdin": {
      "hook_event_name": "PostToolUse",
      "tool_name": "Bash",
      "tool_input": {
        "command": "ls -la"
      },
      "session_id": "test-session-success"
    },
    "setup": {
      ".harness/.gitkeep": ""
    },
    "expect": {
      "exitCode": 0,
      "stdout": "empty",
      "files": {
        ".harness/observations.jsonl": {
          "contains": "\"status\":\"success\""
        }
      }
    }
  },
  {
    "name": "session-logger: Agent 工具 → 记录描述和 prompt",
    "hook": "session-logger.js",
    "stdin": {
      "tool_name": "Agent",
      "tool_input": {
        "description": "run tests",
        "prompt": "Execute the test suite"
      },
      "session_id": "test-session-002"
    },
    "setup": {
      ".harness/.gitkeep": ""
    },
    "expect": {
      "exitCode": 0,
      "stdout": "empty",
      "files": {
        ".harness/session-log.md": {
          "contains": "Agent 派发"
        },
        ".harness/observations.jsonl": {
          "contains": "run tests"
        }
      }
    }
  },
  {
    "name": "session-logger: HARNESS_LOG=off → 不写任何文件",
    "hook": "session-logger.js",
    "stdin": {
      "tool_name": "Bash",
      "tool_input": {
        "command": "echo hi"
      }
    },
    "env": {
      "HARNESS_LOG": "off"
    },
    "expect": {
      "exitCode": 0,
      "stdout": "empty",
      "files": {
        ".harness/session-log.md": {
          "exists": false
        },
        ".harness/observations.jsonl": {
          "exists": false
        }
      }
    }
  },
  {
    "name": "session-logger: 无效 JSON stdin → 不崩溃",
    "hook": "session-logger.js",
    "stdin": null,
    "expect": {
      "exitCode": 0
    }
  },
  {
    "name": "session-logger: PostToolUseFailure Bash → 记录失败到 session-log + observations",
    "hook": "session-logger.js",
    "stdin": {
      "session_id": "abc123",
      "hook_event_name": "PostToolUseFailure",
      "tool_name": "Bash",
      "tool_input": {
        "command": "npm test",
        "description": "Run test suite"
      },
      "tool_use_id": "toolu_01ABC123",
      "error": "Command exited with non-zero status code 1",
      "is_interrupt": false
    },
    "setup": {
      ".harness/.gitkeep": ""
    },
    "expect": {
      "exitCode": 0,
      "stdout": "empty",
      "files": {
        ".harness/session-log.md": {
          "contains": [
            "[失败] Bash 执行",
            "npm test",
            "**错误**:",
            "Command exited with non-zero status code 1"
          ]
        },
        ".harness/observations.jsonl": {
          "contains": [
            "\"status\":\"failure\"",
            "\"error\":",
            "Command exited with non-zero status code 1"
          ]
        }
      }
    }
  },
  {
    "name": "session-logger: 脱敏 — api_key 被替换",
    "hook": "session-logger.js",
    "stdin": {
      "tool_name": "Bash",
      "tool_input": {
        "command": "curl -H api_key=sk-secret123 https://example.com"
      }
    },
    "setup": {
      ".harness/.gitkeep": ""
    },
    "expect": {
      "exitCode": 0,
      "files": {
        ".harness/observations.jsonl": {
          "contains": "[REDACTED]"
        }
      }
    }
  },
  {
    "name": "session-logger: StopFailure (rate_limit) → 写入 API 错误标记，不走旧路径",
    "hook": "session-logger.js",
    "stdin": {
      "hook_event_name": "StopFailure",
      "error_type": "rate_limit",
      "session_id": "sess-rl-001"
    },
    "setup": {
      ".harness/.gitkeep": ""
    },
    "expect": {
      "exitCode": 0,
      "stdout": "empty",
      "files": {
        ".harness/session-log.md": {
          "contains": [
            "[API 错误] StopFailure",
            "rate_limit",
            "sess-rl-001"
          ],
          "containsNot": ["Bash 执行", "Agent 派发", "[失败] "]
        },
        ".harness/observations.jsonl": {
          "contains": [
            "\"tool\":\"StopFailure\"",
            "\"status\":\"api_error\"",
            "\"error_type\":\"rate_limit\""
          ],
          "containsNot": ["\"status\":\"success\"", "\"status\":\"failure\""]
        }
      }
    }
  },
  {
    "name": "session-logger: StopFailure (server_error) → 写入",
    "hook": "session-logger.js",
    "stdin": {
      "hook_event_name": "StopFailure",
      "error_type": "server_error",
      "session_id": "sess-srv"
    },
    "setup": {
      ".harness/.gitkeep": ""
    },
    "expect": {
      "exitCode": 0,
      "files": {
        ".harness/session-log.md": { "contains": "server_error" },
        ".harness/observations.jsonl": { "contains": "\"error_type\":\"server_error\"" }
      }
    }
  },
  {
    "name": "session-logger: StopFailure 缺 error_type → fallback unknown",
    "hook": "session-logger.js",
    "stdin": {
      "hook_event_name": "StopFailure",
      "session_id": "sess-no-type"
    },
    "setup": {
      ".harness/.gitkeep": ""
    },
    "expect": {
      "exitCode": 0,
      "files": {
        ".harness/session-log.md": { "contains": "unknown" },
        ".harness/observations.jsonl": { "contains": "\"error_type\":\"unknown\"" }
      }
    }
  },
  {
    "name": "session-logger: StopFailure + HARNESS_LOG=off → 不写文件",
    "hook": "session-logger.js",
    "stdin": {
      "hook_event_name": "StopFailure",
      "error_type": "rate_limit"
    },
    "env": { "HARNESS_LOG": "off" },
    "expect": {
      "exitCode": 0,
      "files": {
        ".harness/session-log.md": { "exists": false },
        ".harness/observations.jsonl": { "exists": false }
      }
    }
  },
  {
    "name": "session-logger: StopFailure + HARNESS_LEARN=off → 只写 session-log，不写 observations",
    "hook": "session-logger.js",
    "stdin": {
      "hook_event_name": "StopFailure",
      "error_type": "billing_error",
      "session_id": "sess-no-learn"
    },
    "env": { "HARNESS_LEARN": "off" },
    "setup": {
      ".harness/.gitkeep": ""
    },
    "expect": {
      "exitCode": 0,
      "files": {
        ".harness/session-log.md": { "contains": "billing_error" },
        ".harness/observations.jsonl": { "exists": false }
      }
    }
  }
]
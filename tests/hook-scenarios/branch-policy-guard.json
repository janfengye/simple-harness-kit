[
  {
    "name": "branch-policy-guard: example-company + push to master → block",
    "hook": "branch-policy-guard.js",
    "kitPresets": true,
    "env": { "HARNESS_PRESET": "example-company" },
    "stdin": {
      "tool_name": "Bash",
      "tool_input": { "command": "git push origin master" }
    },
    "expect": {
      "exitCode": 2,
      "stderr": ["Direct push to 'master'", "merge-only"],
      "stdout": "empty"
    }
  },
  {
    "name": "branch-policy-guard: example-company + push to feature-1234-AI-TEST → block (matches feature-*)",
    "hook": "branch-policy-guard.js",
